{
  "enabled": true,
  "name": "Auto Lint on Save",
  "description": "Automatically runs ESLint when TypeScript or JavaScript files are saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.ts",
      "*.tsx",
      "*.js",
      "*.jsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint"
  }
}